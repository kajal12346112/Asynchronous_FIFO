module sync_ptr (
    input clk,
    input rst,
    input [2:0] ptr_in,

    output reg [2:0] ptr_out
);

reg [2:0] temp;

always @(posedge clk or posedge rst)
begin
    if (rst)
    begin
        temp <= 0;
        ptr_out <= 0;
    end
    else
    begin
        temp <= ptr_in;
        ptr_out <= temp;
    end
end

endmodule